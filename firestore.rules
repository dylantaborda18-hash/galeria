rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Images collection
    match /images/{imageId} {
      // Allow anyone to read the gallery
      allow read: if true;
      
      // For this prototype, we allow writes. 
      // In a production app, this should be restricted to an admin user.
      allow create, update, delete: if true;
    }
    
    // Test collection for connection check
    match /test/connection {
      allow read: if true;
    }
  }
}
